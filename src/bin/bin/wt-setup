#!/bin/bash

# Exit if no URL provided
if [ -z "$1" ]; then
    echo "Usage: wt-setup <repo-url>"
    exit 1
fi

REPO_URL=$1
# Extract repo name from URL (removes .git and path)
REPO_NAME=$(basename "$REPO_URL" .git)

echo "--- Initializing Worktree Project: $REPO_NAME ---"

# 1. Create and enter the project root
mkdir "$REPO_NAME" && cd "$REPO_NAME"

# 2. Clone the repo data into a hidden .bare folder
git clone --bare "$REPO_URL" .bare

# 3. Create the 'magic' pointer file
echo "gitdir: ./.bare" > .git

# 4. Fix fetch configuration (Bare clones don't track remotes by default)
cd .bare
git config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
cd ..

# 5. Fetch all branches
git fetch origin

# 6. Create the primary 'main' worktree
# (Adjust 'main' to 'master' if your repo uses the old default)
git worktree add main

echo "--- Setup Complete ---"
echo "Project ready at: \$(pwd)"
echo "Run 'cd $REPO_NAME/main' to start working,"
echo "or 'wt switch -c feat' from the root to add a branch folder."
